          "accountName": "[parameters('storageAccountName')]",
          "shareName": "[parameters('storageShareName')]",
          "accountKey": "[parameters('storageAccountKey')]",
          "accessMode": "ReadWrite"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]"
      ]
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "tags": "[union(parameters('tags'), createObject('azd-service-name', 'web'))]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', parameters('managedIdentityId'))]": {}
        }
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]",
        "workloadProfileName": "Consumption",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "copy": [
              {
                "name": "ipSecurityRestrictions",
                "count": "[length(variables('parsedIpRestrictions'))]",
                "input": {
                  "name": "[format('allow-{0}', copyIndex('ipSecurityRestrictions'))]",
                  "ipAddressRange": "[trim(variables('parsedIpRestrictions')[copyIndex('ipSecurityRestrictions')])]",
                  "action": "Allow"
                }
              }
            ],
            "external": true,
            "targetPort": 3000,
            "transport": "auto",
            "allowInsecure": false,
            "corsPolicy": {
              "allowedOrigins": "[if(empty(parameters('allowedOrigins')), createArray(format('https://{0}.{1}', parameters('name'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('environmentName')), '2024-03-01').defaultDomain)), union(createArray(format('https://{0}.{1}', parameters('name'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('environmentName')), '2024-03-01').defaultDomain)), split(parameters('allowedOrigins'), ',')))]",
              "allowedMethods": [
                "GET",
                "POST"
              ],
              "allowedHeaders": [
                "Content-Type",
                "Authorization"
              ],
              "maxAge": 3600
            }
          },
          "registries": [
            {
              "server": "[parameters('containerRegistryLoginServer')]",
              "identity": "[parameters('managedIdentityId')]"
            }
          ],
          "secrets": "[concat(if(variables('useKeyVault'), createArray(createObject('name', 'github-client-id', 'keyVaultUrl', format('{0}secrets/github-client-id', parameters('keyVaultUri')), 'identity', parameters('managedIdentityId')), createObject('name', 'session-secret', 'keyVaultUrl', format('{0}secrets/session-secret', parameters('keyVaultUri')), 'identity', parameters('managedIdentityId'))), createArray(createObject('name', 'github-client-id', 'value', parameters('githubClientId')), createObject('name', 'session-secret', 'value', parameters('sessionSecret')))), createArray(createObject('name', 'appinsights-connection-string', 'value', parameters('appInsightsConnectionString'))), if(variables('hasAllowedUsers'), createArray(createObject('name', 'allowed-github-users', 'value', parameters('allowedGithubUsers'))), createArray()))]"
        },
        "template": {
          "volumes": "[if(variables('hasStorage'), createArray(createObject('name', 'copilot-data', 'storageName', 'copilot-data', 'storageType', 'AzureFile')), createArray())]",
          "containers": [
            {
              "name": "copilot-unleashed",
              "image": "[parameters('image')]",
              "env": "[concat(createArray(createObject('name', 'NODE_ENV', 'value', 'production'), createObject('name', 'PORT', 'value', '3000'), createObject('name', 'BASE_URL', 'value', format('https://{0}.{1}', parameters('name'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('environmentName')), '2024-03-01').defaultDomain)), createObject('name', 'GITHUB_CLIENT_ID', 'secretRef', 'github-client-id'), createObject('name', 'SESSION_SECRET', 'secretRef', 'session-secret'), createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'secretRef', 'appinsights-connection-string'), createObject('name', 'COPILOT_CONFIG_DIR', 'value', '/data/copilot-home'), createObject('name', 'CHAT_STATE_PATH', 'value', '/data/chat-state'), createObject('name', 'PUSH_STORE_PATH', 'value', '/data/push-subscriptions')), if(variables('hasAllowedUsers'), createArray(createObject('name', 'ALLOWED_GITHUB_USERS', 'secretRef', 'allowed-github-users')), createArray()))]",
              "resources": {
                "cpu": "[json(parameters('cpuCores'))]",
                "memory": "[parameters('memoryGi')]"
              },
              "volumeMounts": "[if(variables('hasStorage'), createArray(createObject('volumeName', 'copilot-data', 'mountPath', '/data')), createArray())]",
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/health",
                    "port": 3000
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/health",
                    "port": 3000
                  },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 10,
                  "failureThreshold": 3
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": "[parameters('maxReplicas')]",
            "rules": [
              {
                "name": "http-rule",
                "http": {
                  "metadata": {
                    "concurrentRequests": "10"
                  }
                }
              }
            ]
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]"
      ]
    }
