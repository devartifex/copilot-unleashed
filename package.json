{
  "name": "copilot-cli-mobile",
  "version": "2.0.0",
  "description": "Copilot CLI Mobile — GitHub OAuth + Copilot SDK",
  "main": "build/index.js",
  "scripts": {
    "dev": "vite dev",
    "dev:docker": "docker compose up --build",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build/index.js",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "clean": "rm -rf build dist .svelte-kit",
    "postinstall": "node scripts/patch-sdk.mjs"
  },
  "keywords": [
    "copilot",
    "cli",
    "mobile",
    "github",
    "oauth"
  ],
  "license": "MIT",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.53.4",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.0",
    "helmet": "^8.0.0",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.1.0",
    "marked": "^17.0.4",
    "session-file-store": "^1.5.0",
    "svelte": "^5.53.9",
    "vite": "^7.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.17.0",
    "@types/session-file-store": "^1.2.6",
    "@types/ws": "^8.5.13",
    "svelte-check": "^4.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
